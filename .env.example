# ============================================================
# dist-telemetry-exp — Environment Variables Reference
# Copy to .env and adjust for local overrides (never commit .env)
# docker-compose.yml already sets these for container networking
# ============================================================

# ---- TelemetryApi ----
# LiteDB file path (inside the container, mapped to the litedb-data volume)
LiteDb__ConnectionString=./data/telemetry.db

# ---- MachineSimulator ----
# MQTT broker hostname (use 'hivemq' in docker-compose, 'localhost' for local dev)
Mqtt__Host=localhost
# How often to publish a reading (seconds)
Mqtt__PublishIntervalSeconds=5

# ---- Orchestrator ----
# MQTT broker hostname
Mqtt__Host=localhost
# TelemetryApi base URL (use 'http://telemetry-api:8080' in docker-compose)
Api__BaseUrl=http://localhost:5001

# ---- Shared: OpenTelemetry ----
# OTLP gRPC endpoint for all services (use 'http://jaeger:4317' in docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317